# ============================================================================
# Supressões Genéricas para Bibliotecas de Sistema (Últimos Recursos)
# ============================================================================
{
   External_Libs_Calloc_Leaks
   Memcheck:Leak
   match-leak-kinds: all
   fun:calloc
   ...
   fun:mlx_init*
}

{
   External_Libs_Calloc_All
   Memcheck:Leak
   match-leak-kinds: all
   fun:calloc
   ...
}

{
   External_Libs_Calloc_Still_Reachable
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:calloc
   ...
}

{
   External_Libs_Malloc_Leaks
   Memcheck:Leak
   match-leak-kinds: all
   fun:malloc
   ...
   fun:mlx_init*
}

{
   External_Libs_Malloc_All
   Memcheck:Leak
   match-leak-kinds: all
   fun:malloc
   ...
}

{
   External_Libs_Malloc_Indirect
   Memcheck:Leak
   match-leak-kinds: indirect
   fun:malloc
   ...
}

{
   External_Libs_Memalign_Leaks
   Memcheck:Leak
   match-leak-kinds: all
   fun:memalign
   ...
}
