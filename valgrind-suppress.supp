# ============================================================================
# Supressões Valgrind para Bibliotecas Externas do Sistema
# Projeto: cub3d
# Ignora problemas de bibliotecas gráficas (OpenGL, X11, GLFW, WSL, etc)
# ============================================================================

# ============================================================================
# Mismatched Free/Delete (bibliotecas externas)
# ============================================================================
{
   Intel_GMM_Mismatched_Delete
   Memcheck:Free
   fun:_ZdlPv
   fun:_ZN6GmmLib16GmmClientContext11DestroyPoolEPv
   ...
}

{
   WSL_Drivers_Mismatched_Free
   Memcheck:Free
   ...
   obj:*/libigdgmm_w.so*
   ...
   obj:*/libigd12um64xel.so
}

# ============================================================================
# WSL / DirectX Core
# ============================================================================
{
   WSL_DXCore_Conditional_Jump
   Memcheck:Cond
   ...
   obj:*/libdxcore.so
}

{
   WSL_DXCore_Value
   Memcheck:Value8
   ...
   obj:*/libdxcore.so
}

{
   WSL_DXCore_IOCTL_Uninit
   Memcheck:Param
   ioctl(generic)
   fun:ioctl
   fun:D3DKMTLock2
   ...
}

{
   WSL_DXCore_IOCTL_Query_Uninit
   Memcheck:Param
   ioctl(generic)
   fun:ioctl
   fun:D3DKMTQueryAdapterInfo
   ...
}

{
   WSL_DXCore_All_Leaks
   Memcheck:Leak
   match-leak-kinds: all
   ...
   obj:*/libdxcore.so
}

